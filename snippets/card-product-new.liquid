{%- liquid 
  assign current_variant = product.selected_or_first_available_variant
  
  assign main_card_image = current_variant.featured_image | default: product.featured_image
  assign hover_card_image = product.images[1] | default: main_card_image

  assign on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
  endif
-%}

<div class="product-card relative justify-between flex flex-col" data-product-card data-product-id="{{ product.id }}">
  {% comment %} Imagens com fallback via Liquid {% endcomment %}
  <a href="{{ product.url | within: collection }}" class="group mb-4 border border-[#e8e8e8] product-card-link relative block overflow-hidden rounded-[10px]">
    <img 
      src="{{ main_card_image | image_url: width: 315, height: 340 }}"
      alt="{{ main_card_image.alt | default: product.title }}"
      class="main-image h-full w-full object-cover object-center transition-opacity duration-500"
      data-main-image>
    
    <img 
      src="{{ hover_card_image | image_url: width: 315, height: 340 }}"
      alt="{{ hover_card_image.alt | default: product.title }}"
      class="absolute inset-0 h-full w-full object-cover object-center opacity-0 transition-opacity duration-500 group-hover:opacity-100"
      data-hover-image>
  </a>

  {% if product.variants.size > 1 %}
    <div class="flex mb-4 items-center gap-2" data-swatch-container>
      {% for variant in product.variants %}
        {%- liquid 
          assign variant_img = variant.featured_image | default: product.featured_image
          assign next_idx = variant_img.position
          assign v_hover_img = product.images[next_idx] | default: variant_img
        -%}

        <button type="button"
          class="swatch-item p-0 h-6 w-6 rounded-full ring-offset-1 transition-all {% if variant.id == current_variant.id %}ring-1 ring-domaineBlue active-swatch{% endif %}"
          style="background-color: {{ variant.options[0] | handle }};"
          data-main-img="{{ variant_img | image_url: width: 315, height: 340 }}"
          data-hover-img="{{ v_hover_img | image_url: width: 315, height: 340 }}"
          data-variant-url="{{ variant.url }}"
          data-price="{{ variant.price | money }}"
          data-compare="{{ variant.compare_at_price | money }}"
          data-on-sale="{% if variant.compare_at_price > variant.price %}true{% else %}false{% endif %}"
          aria-label="Color: {{ variant.options[0] }}">
        </button>
      {% endfor %}
    </div>
  {% endif %}

  {% comment %} Informações do Produto {% endcomment %}
  <div class="flex flex-col">
    <span class="text-sm text-domaineBlack">{{ product.vendor }}</span>
    <h3 class="text-base font-medium text-domaineBlue product-title">{{ product.title }}</h3>
    
    <div class="flex items-center gap-2">
      <span class="price-compare text-sm text-domaineBlack line-through {% unless on_sale %}hidden{% endunless %}">
        {{ current_variant.compare_at_price | money }}
      </span>
      <span class="text-sm text-domaineRed price-regular">
        {{ current_variant.price | money }}
      </span>
    </div>
  </div>
</div>