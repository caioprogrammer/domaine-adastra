{%- liquid 
  assign current_variant = product.selected_or_first_available_variant
  
  assign main_img_initial = current_variant.featured_image | default: product.featured_image
  assign next_idx_initial = main_img_initial.position
  assign hover_img_initial = product.images[next_idx_initial]

  assign on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign on_sale = true
  endif
  
  assign show_swatches = false
  if product.variants.size > 1
    assign show_swatches = true
  endif
-%}

<div class="product-card justify-between relative flex flex-col" 
     x-data="{ 
        mainImage: '{{ main_img_initial | image_url: width: 315, height: 340 }}',
        hoverImage: '{{ hover_img_initial | image_url: width: 315, height: 340 }}',
        price: '{{ current_variant.price | money }}',
        comparePrice: '{{ current_variant.compare_at_price | money }}',
        onSale: {{ on_sale }},
        variantUrl: '{{ current_variant.url }}',
        activeVariantId: {{ current_variant.id }}
     }">

  <a :href="variantUrl"
     class="group mb-4 border border-[#e8e8e8] relative block overflow-hidden rounded-[10px]"
     aria-label="{{ product.title }}"
  >
    <span 
      class="absolute top-5 left-5 bg-white border border-domaineRed text-domaineRed text-sm rounded-full px-2 py-1 z-10"   
      x-show="onSale" 
      x-cloak
    >
      {{ 'products.product.on_sale' | t | default: 'On Sale!' }}
    </span>
    
    <img 
      :src="mainImage"
      alt="{{ product.title }}"
      class="h-full w-full object-cover object-center transition-opacity duration-500"
      loading="lazy">
    {% if hover_img_initial %}
    <img 
      :src="hoverImage"
      alt="{{ product.title }}"
      class="absolute inset-0 h-full w-full object-cover object-center opacity-0 transition-opacity duration-500 group-hover:opacity-100">
    {% endif %}
  </a>

  {% if show_swatches %}
    <div class="flex mb-4 items-center gap-2">
      {% for variant in product.variants %}
        {%- liquid 
          assign variant_img = variant.featured_image | default: product.featured_image
          assign variant_next_idx = variant_img.position
          assign variant_hover = product.images[variant_next_idx] | default: variant_img
        -%}
        <button
          type="button"
          @click="
            mainImage = '{{ variant_img | image_url: width: 315, height: 340 }}';
            hoverImage = '{{ variant_hover | image_url: width: 315, height: 340 }}';
            price = '{{ variant.price | money }}';
            comparePrice = '{{ variant.compare_at_price | money }}';
            onSale = {% if variant.compare_at_price > variant.price %}true{% else %}false{% endif %};
            variantUrl = '{{ variant.url }}';
            activeVariantId = {{ variant.id }};
          "
          class="p-0 h-6 w-6 rounded-full ring-offset-1 transition-all focus:outline-none"
          :class="activeVariantId === {{ variant.id }} ? 'ring-1 ring-domaineBlue' : ''"
          style="background-color: {{ variant.options[0] | handle }};"
          aria-label="{{ 'products.product.color_swatch' | t | default: 'Color' }}: {{ variant.options[0] }}">
        </button>
      {% endfor %}
    </div>
  {% endif %}

  {% comment %} Info {% endcomment %}
  <div class="flex flex-col">
    <span class="text-sm text-domaineBlack">{{ product.vendor }}</span>
    <h3 class="text-base font-medium text-domaineBlue">{{ product.title }}</h3>
    
    <div class="flex items-center gap-2">
      <span class="text-sm text-domaineBlack line-through" 
            x-show="onSale" 
            x-text="comparePrice"
            x-cloak>
      </span>
      <span class="text-sm text-domaineRed" x-text="price"></span>
    </div>
  </div>
</div>